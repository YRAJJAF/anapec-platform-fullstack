# ── ANAPEC Platform — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit the real .env file to version control

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://anapec_user:anapec_secret_2024@localhost:5432/anapec_db
POSTGRES_PASSWORD=anapec_secret_2024

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use long random strings in production (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_this_access_secret_in_production_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2024

# ── S3 / MinIO (Object Storage) ───────────────────────────────────────────────
# For local dev with MinIO (Docker):
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET=anapec-platform
AWS_S3_ENDPOINT=http://localhost:9000   # Remove this for real AWS S3

# For production with AWS S3:
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_S3_BUCKET=anapec-platform-prod
# AWS_S3_ENDPOINT=  # Leave empty for AWS

# MinIO local credentials (for docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ── OpenAI (AI Scoring — optional) ────────────────────────────────────────────
# Leave empty to disable AI scoring (falls back to manual review)
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# ── Email / SMTP ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@anapec-platform.ma

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
